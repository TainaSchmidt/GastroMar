<div class="page-bar">
  <div class="page-title">
    Meu Painel de Pesca
    <small>Gerencie os pescados que você está oferecendo</small>
  </div>
  <%= link_to "+ Cadastrar Novo Pescado", new_pescado_path, class: "btn-primary" %>
</div>

<% if @pescados.any? %>
  <div class="grid">
    <% @pescados.each do |pescado| %>
      <div class="card">
        <div class="card-header">
          <div class="card-icon">⚓</div>
          <span class="card-nome"><%= pescado.nome %></span>
        </div>
        <div class="card-body">
          <div class="info-row">
            <span class="info-label">Estoque</span>
            <span class="info-value"><%= pescado.quantidade %> <%= pescado.unidade %></span>
          </div>
        </div>
        <div class="card-footer" style="display: flex; gap: 10px;">
          <%= link_to "Ver", pescado_path(pescado), class: "btn-detalhes", style: "flex: 1;" %>
          <%= link_to "Editar", edit_pescado_path(pescado), class: "btn-detalhes", style: "flex: 1; background: #64748b;" %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="empty-state">
    <div class="icon">⚓</div>
    <h3>Você ainda não cadastrou nenhum pescado</h3>
    <p>Cadastre sua primeira pesca para que os restaurantes possam encontrá-la.</p>
    <%= link_to "+ Cadastrar Primeiro Pescado", new_pescado_path, class: "btn-primary" %>
  </div>
<% end %>