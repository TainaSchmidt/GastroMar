<div class="form-card">
  <div class="form-card-header">
    <h1>🎣 Cadastrar Novo Pescado</h1>
    <p>Preencha as informações do que você pescou hoje</p>
  </div>

  <div class="form-card-body">
    <% if @pescado.errors.any? %>
        <div style="background: #fef2f2; color: #ef4444; padding: 14px; border-radius: 8px; margin-bottom: 20px; border: 1px solid #fecaca; font-size: 14px;">
            <strong>Ops! Não foi possível salvar o pescado pelos seguintes motivos:</strong>
            <ul style="margin-top: 6px; margin-left: 20px;">
            <% @pescado.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
            <% end %>
            </ul>
        </div>
    <% end %>
    <%= form_with(model: @pescado, local: true) do |f| %>
      
      <div class="section-title">Identificação</div>
      
      <div class="form-group">
        <%= f.label :nome, "Nome do Peixe / Fruto do Mar <span class='required'>*</span>".html_safe %>
        <%= f.text_field :nome, placeholder: "Ex: Camarão, Tainha, Robalo, Lula...", required: true %>
      </div>

      <div class="form-group">
        <%= f.label :descricao, "Descrição / Observações" %>
        <%= f.text_area :descricao, placeholder: "Informações adicionais..." %>
      </div>

      <div class="section-title">Quantidade e Preço</div>

      <div class="row-2">
        <div class="form-group">
          <%= f.label :quantidade, "Quantidade <span class='required'>*</span>".html_safe %>
          <%= f.number_field :quantidade, step: "any", min: 0, required: true %>
        </div>
        <div class="form-group">
          <%= f.label :unidade, "Unidade de Medida <span class='required'>*</span>".html_safe %>
          <%= f.text_field :unidade, placeholder: "kg, unidade, dúzia...", required: true %>
        </div>
      </div>

      <div class="row-2">
        <div class="form-group">
          <%= f.label :preco_por_unidade, "Preço por Unidade (R$)" %>
          <%= f.number_field :preco_por_unidade, step: "0.01", min: 0 %>
          <p class="hint">Deixe em branco para combinar depois</p>
        </div>
        <div class="form-group">
          <%= f.label :data_pesca, "Data da Pesca <span class='required'>*</span>".html_safe %>
          <%= f.date_field :data_pesca, required: true %>
        </div>
      </div>

      <div class="form-actions" style="display: flex; gap: 10px; margin-top: 24px; padding-top: 20px; border-top: 1px solid #e2e8f0;">
        <%= f.submit "✓ Salvar Pescado", class: "btn-primary" %>
        <%= link_to "Cancelar", pescados_path, class: "btn-secondary" %>
      </div>
    <% end %>

    <div class="tip-box">
      <strong>💡 Dica</strong>
      Quanto mais completas as informações, mais fácil para os restaurantes encontrarem o seu pescado.
    </div>
  </div>
</div>