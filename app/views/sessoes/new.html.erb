<div class="form-card" style="max-width: 400px; margin: 40px auto;">
  <div class="form-card-header">
    <h1>Entrar no GastroMar</h1>
    <p>Acesse sua conta para continuar</p>
  </div>

  <div class="form-card-body">
    <%# Mostra o erro de senha caso exista %>
    <% if flash[:alert] %>
      <div style="background: #fef2f2; color: #ef4444; padding: 12px; border-radius: 8px; margin-bottom: 20px; text-align: center; border: 1px solid #fecaca;">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <%= form_with(url: login_path, local: true) do |f| %>
      <div class="form-group">
        <%= f.label :login, "Nome de Usuário (Login)" %>
        <%= f.text_field :login, placeholder: "Ex: zepescador", required: true %>
      </div>

      <div class="form-group">
        <%= f.label :senha, "Senha" %>
        <%= f.password_field :senha, placeholder: "Sua senha", required: true %>
      </div>

      <div class="form-actions" style="margin-top: 24px;">
        <%= f.submit "Entrar", class: "btn-primary", style: "width: 100%; justify-content: center;" %>
      </div>
    <% end %>
  </div>
</div>